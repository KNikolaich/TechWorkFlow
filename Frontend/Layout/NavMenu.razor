@using Frontend.Services
@inject ICurrentUserService CurrentUserService

<MudNavMenu Class="tw-navmenu">
    <MudText Typo="Typo.overline" Class="tw-nav-section">Общее</MudText>
    <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">
        Дэшборд
    </MudNavLink>

    @if (_currentUser?.IsAuthenticated == true)
    {
        if (_currentUser.Role is AuthRoles.Admin or AuthRoles.Supervisor)
        {
            <MudText Typo="Typo.overline" Class="tw-nav-section">Заявки</MudText>
            <MudNavLink Href="tasks" Icon="@Icons.Material.Filled.ListAlt">
                Все заявки
            </MudNavLink>
            <MudNavLink Href="tasks/new" Icon="@Icons.Material.Filled.AddCircleOutline">
                Новая заявка
            </MudNavLink>
        }

        if (_currentUser.Role is AuthRoles.Worker)
        {
            <MudText Typo="Typo.overline" Class="tw-nav-section">Моя работа</MudText>
            <MudNavLink Href="my-tasks" Icon="@Icons.Material.Filled.AssignmentInd">
                Мои заявки
            </MudNavLink>
        }

        if (_currentUser.Role is AuthRoles.Admin)
        {
            <MudText Typo="Typo.overline" Class="tw-nav-section">Администрирование</MudText>
            <MudNavLink Href="admin/equipment" Icon="@Icons.Material.Filled.Build">
                Оборудование
            </MudNavLink>
            <MudNavLink Href="admin/clubs" Icon="@Icons.Material.Filled.LocationCity">
                Клубы
            </MudNavLink>
            <MudNavLink Href="admin/zones" Icon="@Icons.Material.Filled.GridView">
                Зоны
            </MudNavLink>
            <MudNavLink Href="admin/users" Icon="@Icons.Material.Filled.People">
                Работники
            </MudNavLink>
        }
    }

    <MudText Typo="Typo.overline" Class="tw-nav-section">Аккаунт</MudText>
    <MudNavLink Href="account" Icon="@Icons.Material.Filled.Settings">
        Личный кабинет
    </MudNavLink>
</MudNavMenu>

@code {
    private CurrentUser? _currentUser;

    protected override async Task OnInitializedAsync()
    {
        _currentUser = await CurrentUserService.GetCurrentUserAsync();
    }
}
