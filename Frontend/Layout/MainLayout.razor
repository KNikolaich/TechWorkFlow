@inherits LayoutComponentBase
@using Frontend.Services
@inject ICurrentUserService CurrentUserService

<MudLayout>
    <MudAppBar Elevation="1" Dense="true" Color="Color.Default" Class="tw-appbar">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@ToggleDrawer" Class="mud-ripple-icon" />
        <MudText Typo="Typo.h6" Class="tw-appbar-title">TechWorkFlow</MudText>

        <MudSpacer />

        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <MudText Typo="Typo.body2" Class="tw-user-chip">@_userLabel</MudText>
        </MudHidden>

        <MudMenu Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit">
            <MudMenuItem Href="account">Личный кабинет</MudMenuItem>
            <MudMenuItem Href="logout">Выйти</MudMenuItem>
        </MudMenu>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="1" Variant="DrawerVariant.Responsive" Class="tw-drawer">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Class="tw-main">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private string _userLabel = "Гость";

    protected override async Task OnInitializedAsync()
    {
        var user = await CurrentUserService.GetCurrentUserAsync();
        _userLabel = user.IsAuthenticated
            ? $"{user.FullName} ({user.Role})"
            : "Гость";
    }

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }
}
